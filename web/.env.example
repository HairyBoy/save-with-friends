# Copy to .env.local for local dev, or set these in your host (Vercel) project env.
# Anything WITHOUT a NEXT_PUBLIC_ prefix is server-only and never reaches the client.

# Target chain: "anvil" (local dev, the default), "celoSepolia" (testnet), or
# "celo" (mainnet — REAL FUNDS). On mainnet, set the mainnet vars below and make
# sure ENABLE_DEV_APPROVE stays false.
NEXT_PUBLIC_CHAIN=celoSepolia

# Deployed SavingsVaults address on the selected chain. Public (it's on-chain).
# Required when NEXT_PUBLIC_CHAIN=celoSepolia. This is the verified Sepolia vault.
# On mainnet there is NO baked default (chains.ts uses "0x") — you MUST set this to
# the verified mainnet deploy, or solo writes fail fast.
NEXT_PUBLIC_SAVINGS_VAULTS_ADDRESS=0x54fc67b6f9f8b0111c1c86037c075efc30b1a20c

# Deployed SharedVaults (group savings) on the selected chain. Has a default baked
# into chains.ts for Sepolia; set this only to override. On mainnet there is NO
# default — you MUST set it to the verified mainnet deploy.
NEXT_PUBLIC_SHARED_VAULTS_ADDRESS=0xFA72C790C970F2bB76994E6a88219B4F420433e9

# SERVER-ONLY: the dedicated Celo Sepolia RPC that the /api/rpc proxy forwards to
# (e.g. an Alchemy URL). Keeps the key out of the client bundle. Required on testnet.
CELO_SEPOLIA_RPC=https://celo-sepolia.g.alchemy.com/v2/YOUR_KEY

# SERVER-ONLY: dedicated Celo MAINNET RPC for the /api/rpc proxy. Required when
# NEXT_PUBLIC_CHAIN=celo. (Mainnet USDC token + fee-currency adapter are baked into
# chains.ts; only the deploy addresses + this RPC come from env.)
CELO_MAINNET_RPC=https://celo-mainnet.g.alchemy.com/v2/YOUR_KEY

# SERVER-ONLY: Neon (Postgres) connection string for the synced friends list +
# vault names. Set by the Vercel↔Neon integration in prod; paste it here for dev.
# If unset, the friends/vault-name API returns 503 (the rest of the app still works).
DATABASE_URL=postgres://USER:PASSWORD@HOST/DB?sslmode=require

# --- DEV/TEST ONLY: friend-key approval route (/api/dev/approve-as) ---
# The route is OFF unless this is exactly "true" AND the chain is celoSepolia.
# It signs with embedded testnet keys — never enable on a mainnet/production deploy.
ENABLE_DEV_APPROVE=false
# SERVER-ONLY testnet friend wallet keys, used only by the dev approve route.
ANA_PK=0xYOUR_TESTNET_ANA_KEY
LUIS_PK=0xYOUR_TESTNET_LUIS_KEY
